# Copy this file to .env and fill in real values yourself.
# Never commit the real .env file.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# The organization id a public inquiry is attributed to (Nashville Chef
# Service in the pilot). Used by the public intake screen. Safe to expose in
# the client bundle; server-side RLS still governs all data access.
EXPO_PUBLIC_DEFAULT_ORG_ID=
