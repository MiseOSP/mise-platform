# Copy this file to .env and fill in real values yourself.
# Never commit the real .env file.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# The organization id a public inquiry is attributed to (Nashville Chef
# Service in the pilot). Used by the public intake screen. Safe to expose in
# the client bundle; server-side RLS still governs all data access.
EXPO_PUBLIC_DEFAULT_ORG_ID=

# Stripe PUBLISHABLE key (starts with pk_test_ / pk_live_). This is the
# client-side key and is safe to ship in the app bundle. Used by the deposit
# checkout flow. The matching SECRET key (sk_...) must NEVER go here -- it lives
# only in the Edge Function environment (supabase secrets set STRIPE_SECRET_KEY).
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
